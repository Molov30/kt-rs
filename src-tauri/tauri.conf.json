{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "kt-rs",
    "version": "0.1.0",
    "identifier": "kt-rs",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "kt-rs",
                "width": 800,
                "height": 600,
                "devtools": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["deb", "appimage"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "shortDescription": "kt-rs",
        "longDescription": "kt-rs",
        "category": "Utilities",
        "linux": {
            "deb": {
                "depends": [
                    "libwebkit2gtk-4.1-0",
                    "libgtk-3-0",
                    "libglib2.0-0"
                ],
                "section": "utils",
                "priority": "optional",
                "postInstallScript": "deb-postinst.sh",
                "files": {
                    "/usr/share/applications/kt-rs.desktop": "kt-rs.desktop",
                    "/usr/lib/kt-rs/kt-rs-launcher.sh": "kt-rs-launcher.sh"
                }
            },
"appimage": {
                "bundleMediaFramework": false
            }
        }
    }
}
